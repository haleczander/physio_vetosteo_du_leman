---
import tariffs from "../data/tariffs.json";

type TariffPricedRow = {
  type: "priced";
  label: string;
  meta?: string;
  details?: string[];
  price: string;
};

type TariffNoteRow = {
  type: "note";
  text: string;
};

type TariffRow = TariffPricedRow | TariffNoteRow;

type TariffSection = {
  title: string;
  rows: TariffRow[];
};

type TariffData = {
  effectiveDate: string;
  vatRate: number;
  sections: TariffSection[];
};

const tariffData = tariffs as TariffData;

const hasDetails = (row: TariffPricedRow) => Boolean(row.meta || row.details?.length);
---

<Fragment>
  <h3>Tarifs en vigueur au {tariffData.effectiveDate}*</h3>

  {tariffData.sections.map((section) => (
    <table class="tarifs-specialite">
      <thead>
        <tr>
          <th colspan="2">{section.title}</th>
        </tr>
      </thead>
      <tbody>
        {section.rows.map((row) =>
          row.type === "note" ? (
            <tr>
              <td colspan="2"><i>{row.text}</i></td>
            </tr>
          ) : (
            <tr>
              <td>
                {hasDetails(row) ? (
                  <p>
                    <b>{row.label}</b>
                    {row.meta && `, ${row.meta}`}
                    {row.details?.map((detail) => (
                      <Fragment>
                        <br />
                        {detail}
                      </Fragment>
                    ))}
                  </p>
                ) : (
                  <b>{row.label}</b>
                )}
              </td>
              <td>{row.price}</td>
            </tr>
          ),
        )}
      </tbody>
    </table>
  ))}

  <ul class="tarifs-infos no-dot">
    <li>*Tous les actes incluent {tariffData.vatRate}% de TVA, en vigueur au {tariffData.effectiveDate}.</li>
  </ul>
</Fragment>
