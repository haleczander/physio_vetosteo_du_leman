---
interface Props {
  imageSrc: string;
  imageAlt: string;
  category: string;
  name: string;
  species: string[];
  equipment: string;
  description: string;
  href: string;
}

const { imageSrc, imageAlt, category, name, species, equipment, description, href } = Astro.props;

const speciesIconMap: Record<string, string | undefined> = {
  Chat: "fas fa-cat",
  Chien: "fas fa-dog",
  Cheval: "fas fa-horse",
  NAC: undefined,
};
---

<article class="equipement-card shadow-light">
  <div class="equipement-media">
    <img src={imageSrc} alt={imageAlt} />
  </div>
  <div class="equipement-body">
    <p class="equipement-kicker">{category}</p>
    <h3>{name}</h3>
    <p class="equipement-species" aria-label="Animaux concernés">
      {species.map((label) =>
        speciesIconMap[label] ? (
          <i class={`${speciesIconMap[label]} icon`}><span>{label}</span></i>
        ) : (
          <span class="icon">{label}</span>
        ),
      )}
    </p>
    <p class="equipement-meta"><b>Matériel</b> {equipment}</p>
    <p class="equipement-description">{description}</p>
    <a href={href} title="En savoir plus">En savoir plus</a>
  </div>
</article>
