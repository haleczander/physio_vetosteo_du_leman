---
import navigation from "../data/navigation.json";

interface Props {
  title: string;
}

const { title } = Astro.props;
const navClass = "nav";
const headerLinks = navigation.header;
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const internalHeaderLinks = headerLinks.flat().filter((link) => link.href.startsWith("/"));
const currentNavLink = internalHeaderLinks.find((link) => {
  const linkPath = link.href.split("#")[0].replace(/\/+$/, "") || "/";
  return linkPath === currentPath;
});
---

<div id="nav" class={navClass}>
  <input type="checkbox" id="nav-cb" />
  <label for="nav-cb" class="hamburger shadow-light">
    <span class="visually-hidden">Ouvrir le menu de navigation</span>
    <span class="hamburger-line"></span>
  </label>

  <a href="/" title="Physio Vet&apos;Ost&eacute;o du L&eacute;man" class="logo shadow-light">
    <img src="/images/logo.svg" alt="Physio Vet&apos;Ost&eacute;o du L&eacute;man - Logo" />
  </a>

  <nav>
    {headerLinks.map((group) => (
      <ul>
        {group.map((link) => (
          <li>
            <a
              href={link.href}
              title={link.title}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
              aria-current={
                link.href.startsWith("/") &&
                ((link.href.split("#")[0].replace(/\/+$/, "") || "/") === currentPath)
                  ? "page"
                  : undefined
              }
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    ))}
  </nav>
</div>
