---
import BaseLayout from "../layouts/BaseLayout.astro";
import openingHours from "../data/opening-hours.json";
---

<BaseLayout
  bodyId="contact"
  title="Physio Vet'Ostéo du Léman - Contact"
  description="Cabinet vétérinaire consacré à la physiothérapie à Marin, Haute-Savoie. Informations pratiques."
  ogTitle="Physio Vet'Ostéo du Léman - Coordonnées"
  ogDescription="Cabinet vétérinaire consacré à la physiothérapie à Marin, Haute-Savoie. Informations pratiques."
  ogUrl="https://physiovetoduleman.com/contact"
  pageTitle="Contact"
>
  <main class="contact">
    <section class="contact-intro">
      <div class="contact-intro-card">
        <h2>Prise de rendez-vous</h2>
        <p>Les rendez-vous se prennent depuis la plateforme <a href="https://www.planningveto.com/rendez-vous-physio-vet-osteo-du-leman-248567" title="Lien vers la plateforme"><b>Planning Véto</b></a>.</p>
        <a class="primary-link" href="https://www.planningveto.com/rendez-vous-physio-vet-osteo-du-leman-248567" title="Prendre rendez-vous">Prendre rendez-vous</a>
      </div>
    </section>

    <section class="contact-grid">
      <article class="contact-card coordonnees">
        <p class="section-label">Coordonnées</p>
        <h2>Nous joindre</h2>
        <ul class="no-dot contact-list">
          <li><i class="fas fa-phone-alt icon"></i><bdo dir="rtl">15 25 61 05 4 33+</bdo></li>
          <li><i class="fas fa-at icon"></i><a href="mailto:physiovetoduleman@gmail.com">physiovetoduleman@gmail.com</a></li>
          <li><i class="fas fa-map-marker-alt icon"></i><span>68 Contre-Allée du Larry, 74200 Marin</span></li>
        </ul>
        <p class="contact-note"><b>En cas d'urgence, la garde vétérinaire est disponible au numéro du cabinet.</b></p>
      </article>

      <article class="contact-card horaires">
        <p class="section-label">Horaires</p>
        <h2>Ouverture du cabinet</h2>
        <table>
          {openingHours.map((entry) => (
            <tr>
              <td>{entry.day}</td>
              <td>{entry.hours}</td>
            </tr>
          ))}
        </table>
      </article>
    </section>

    <section class="map">
      <div class="map-copy">
        <p class="section-label">Accès</p>
        <h2>Nous trouver</h2>
        <p>Le cabinet est situé sur la commune de Marin, entre Évian et Thonon-les-Bains.</p>
      </div>
      <div class="contact-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d265930.0210544716!2d6.354987063499301!3d46.3844400082075!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x478c3c3a631f3193%3A0x6c9bde0f830c5877!2s68%20Contre%20All%C3%A9e%20du%20Larry%2C%2074200%20Marin!5e1!3m2!1sfr!2sfr!4v1619170102591!5m2!1sfr!2sfr"
          width="800"
          height="600"
          style="border:0;"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </section>
  </main>

  <script slot="scripts" is:inline>
    if (window.location.href.indexOf("mail-succes") > -1) {
      alert("Message envoyé avec succès!");
    }
  </script>
</BaseLayout>
